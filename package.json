{
  "name": "pi-agent-core",
  "module": "apps/cli/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run apps/cli/index.ts",
    "ui": "bun --hot run apps/backend/server.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "smoke:orchestrator": "bun run apps/cli/index.ts --smoke orchestrator",
    "smoke:math": "bun run apps/cli/index.ts --smoke math",
    "smoke:code": "bun run apps/cli/index.ts --smoke code",
    "smoke:explorer": "bun run apps/cli/index.ts --smoke explorer",
    "ui:gate": "bun run apps/backend/ui-gate.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
